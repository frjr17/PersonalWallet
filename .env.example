# Firebase web app configuration (Console → Project settings → Your apps).
# These values are not server secrets, but keep real ones out of git anyway.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=personal-budget-demo
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Your Firebase Auth UID. Sign in once, copy it from Authentication → Users.
# Must match the UID hardcoded in firestore.rules (see README).
VITE_FIREBASE_OWNER_UID=YOUR_FIREBASE_OWNER_UID

# App Check via reCAPTCHA Enterprise (optional, production only).
VITE_ENABLE_APP_CHECK=false
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Point the app at the local Firebase Emulator Suite.
VITE_USE_FIREBASE_EMULATORS=false
